APP_ENV=dev
LOG_LEVEL=INFO
GHERKIN_DOMAIN_RULES_FILE=

JIRA_BASE_URL=https://imed.atlassian.net
JIRA_EMAIL=your.email@company.com
JIRA_API_TOKEN=replace_me
JIRA_TIMEOUT_SECONDS=20

CONFLUENCE_BASE_URL=https://imed.atlassian.net/wiki
CONFLUENCE_EMAIL=your.email@company.com
CONFLUENCE_API_TOKEN=replace_me
CONFLUENCE_TIMEOUT_SECONDS=20

GIT_PROVIDER=github
GIT_API_BASE_URL=https://api.github.com
GIT_TOKEN=replace_me
GIT_TIMEOUT_SECONDS=20

XRAY_BASE_URL=https://xray.cloud.getxray.app
XRAY_CLIENT_ID=replace_me
XRAY_CLIENT_SECRET=replace_me
XRAY_TIMEOUT_SECONDS=30

# LLM providers:
# - openai
# - github_models
# - azure_openai
# - openai_compatible
# - ollama
# - lm_studio
LLM_PROVIDER=github_models
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=5000
LLM_TEMPERATURE=0.2

# OpenAI
OPENAI_API_KEY=replace_me
OPENAI_MODEL=gpt-4o-mini

# GitHub Models (recommended when you have GitHub Enterprise access to Models)
# Token needs models:read. GITHUB_TOKEN can be used if GITHUB_MODELS_TOKEN is empty.
GITHUB_MODELS_TOKEN=replace_me
GITHUB_MODELS_MODEL=openai/gpt-4.1
GITHUB_MODELS_ORG=
GITHUB_MODELS_BASE_URL=https://models.github.ai

# Azure OpenAI / Microsoft Foundry
AZURE_OPENAI_API_KEY=replace_me
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# Generic OpenAI-compatible endpoint
LLM_BASE_URL=http://localhost:1234/v1
LLM_API_KEY=replace_me

# Local providers
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1
LM_STUDIO_BASE_URL=http://localhost:1234/v1
LM_STUDIO_MODEL=local-model

RETRY_MAX_ATTEMPTS=3
RETRY_MIN_SECONDS=1
RETRY_MAX_SECONDS=8
